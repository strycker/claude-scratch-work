# Copy this file to .env and fill in your keys.
# .env is git-ignored — never commit real keys.

FRED_API_KEY=your_fred_api_key_here

# Set to "false" to disable SSL certificate verification for yfinance.
# Needed when curl_cffi can't trust your network's certificate chain.
# curl_cffi does NOT use the macOS Keychain or system trust store — adding
# a cert to Keychain has no effect.  This env var is the reliable fix.
# YFINANCE_VERIFY_SSL=false
